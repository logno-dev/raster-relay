{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "strict": true,
    "skipLibCheck": true,
    "resolveJsonModule": true,
    "isolatedModules": true,
    "types": [
      "node",
      "electron"
    ],
    "noEmit": true
  },
  "include": [
    "electron.vite.config.ts",
    "src/main",
    "src/preload",
    "src/shared"
  ]
}
